# DeepSeek API Key（必填）
DEEPSEEK_API_KEY=sk-your-key-here

# 代理配置（访问 YouTube 用，可选）
YTDLP_PROXY=http://127.0.0.1:7892

# yt-dlp SSL 证书验证（默认开启，生产环境保持注释即可）
# 仅在国内网络劫持导致证书错误时临时设为 true
# YTDLP_NO_CHECK_CERTIFICATES=true

# 前端来源白名单（可选，逗号分隔多个域名）
# 不设置则默认允许所有来源（开发模式）
# 生产环境示例：ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com
ALLOWED_ORIGINS=*
